# Frontend URL (for CORS — set to your Vercel deployment URL in production)
CLIENT_URL=http://localhost:5173

# Backend API URL (used internally, not needed for backend itself but documented for reference)
# API runs on this port
PORT=5000

# MongoDB connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/secureUpdateDB

# JWT Secret Key
JWT_SECRET=your_super_secret_key_here
